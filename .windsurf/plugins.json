{
  "plugins": [
    {
      "name": "opencode-windsurf-codeium",
      "version": "0.1.38",
      "description": "OpenCode plugin for Windsurf/Codeium authentication",
      "enabled": true,
      "config": {
        "autoConnect": true,
        "timeout": 30000
      }
    },
    {
      "name": "agileflow",
      "version": "3.4.0",
      "description": "AI-driven agile development system for Claude Code, Cursor, Windsurf",
      "enabled": true,
      "config": {
        "workflowTemplates": true,
        "sprintPlanning": true,
        "retrospectives": true
      }
    },
    {
      "name": "dinq-autopilot",
      "version": "0.2.17",
      "description": "Auto-generate Dinq cards with Code Agents",
      "enabled": true,
      "config": {
        "autoGenerate": true,
        "templateLibrary": true
      }
    },
    {
      "name": "memorix",
      "version": "0.10.0",
      "description": "Cross-Agent Memory Bridge for AI coding agents",
      "enabled": true,
      "config": {
        "persistentMemory": true,
        "crossSessionSync": true,
        "vectorSearch": true
      }
    },
    {
      "name": "kiro-memory",
      "version": "3.0.1",
      "description": "Persistent cross-session memory for AI coding assistants",
      "enabled": true,
      "config": {
        "sqliteStorage": true,
        "vectorSearch": true,
        "typescriptSupport": true
      }
    },
    {
      "name": "@malamute/ai-rules",
      "version": "1.10.0",
      "description": "AI coding tool configurations for multiple frameworks",
      "enabled": true,
      "config": {
        "frameworks": ["angular", "nextjs", "nestjs", "dotnet", "python"],
        "boilerplates": true
      }
    },
    {
      "name": "@donnes/syncode",
      "version": "1.1.9",
      "description": "Sync AI code agent configs across machines and projects",
      "enabled": true,
      "config": {
        "autoSync": true,
        "dotfilesSupport": true
      }
    },
    {
      "name": "slashvibe-mcp",
      "version": "0.4.10",
      "description": "Social MCP server for AI-assisted developers",
      "enabled": true,
      "config": {
        "dms": true,
        "presence": true,
        "discovery": true
      }
    },
    {
      "name": "@aitytech/agentkits-memory",
      "version": "2.3.0",
      "description": "Persistent memory system for AI coding assistants via MCP",
      "enabled": true,
      "config": {
        "sqliteVector": true,
        "mcpProtocol": true
      }
    },
    {
      "name": "tskills",
      "version": "0.2.2",
      "description": "Sync private team AI skills across multiple tools",
      "enabled": true,
      "config": {
        "teamSync": true,
        "skillVersioning": true
      }
    },
    {
      "name": "@agentpmt/mcp-router",
      "version": "1.1.10",
      "description": "Universal MCP server for 8+ AI platforms",
      "enabled": true,
      "config": {
        "platforms": ["claude", "cursor", "vscode", "windsurf", "zed", "codex", "gemini"],
        "autoRouting": true
      }
    },
    {
      "name": "neo-skill",
      "version": "0.1.30",
      "description": "Multi-assistant skill generator for Claude/Windsurf/Cursor/GitHub Skills",
      "enabled": true,
      "config": {
        "canonicalSpec": true,
        "skillGeneration": true
      }
    },
    {
      "name": "@empjs/skill",
      "version": "1.2.0",
      "description": "Unified CLI tool for managing AI agent skills",
      "enabled": true,
      "config": {
        "multiAssistant": true,
        "skillManagement": true
      }
    },
    {
      "name": "comment-rules",
      "version": "1.1.8",
      "description": "Install comment policy rules for AI code editors",
      "enabled": true,
      "config": {
        "autoApply": true,
        "bestPractices": true
      }
    },
    {
      "name": "windsurf-task-manager",
      "version": "1.1.3",
      "description": "Windsurf Task Manager Workflow",
      "enabled": true,
      "config": {
        "taskTracking": true,
        "workflowIntegration": true
      }
    },
    {
      "name": "atris",
      "version": "2.5.0",
      "description": "CLI for AI coding agents. Works with Claude Code, Cursor, Windsurf",
      "enabled": true,
      "config": {
        "codebaseNavigation": true,
        "aiWorkflow": true
      }
    }
  ],
  "globalSettings": {
    "autoUpdate": true,
    "notifications": true,
    "performanceMonitoring": true,
    "errorReporting": true
  },
  "workflows": {
    "enabled": true,
    "templates": [
      {
        "name": "Social Suite Development",
        "description": "Optimized workflow for Social Suite development",
        "steps": [
          "Setup development environment",
          "Run security audit",
          "Execute test suite",
          "Build and deploy",
          "Monitor performance"
        ]
      },
      {
        "name": "AI-Assisted Coding",
        "description": "Leverage AI tools for development",
        "steps": [
          "Initialize memory systems",
          "Load project context",
          "Enable cross-agent sync",
          "Start AI-assisted development",
          "Review and optimize"
        ]
      }
    ]
  },
  "integrations": {
    "claude": {
      "enabled": true,
      "features": ["memory", "context-sharing", "collaboration"]
    },
    "cursor": {
      "enabled": true,
      "features": ["rules-sync", "skill-sharing"]
    },
    "github": {
      "enabled": true,
      "features": ["copilot-integration", "actions-sync"]
    }
  }
}
