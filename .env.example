# ============================================================
# Social Suite — Environment Variables
# ============================================================
# Copy this to .env.local and fill in your secrets:
#   cp .env.example .env.local
#
# Then run the setup script to distribute them:
#   bash scripts/setup-env.sh
#
# .env.local is gitignored — safe for real secrets.
# ============================================================

# ── Supabase (Vite frontend) ────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ── Supabase (MCP / CLI — personal access token) ────────────
SUPABASE_ACCESS_TOKEN=""

# ── Slack Agent Bridge ───────────────────────────────────────
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_CHANNEL_ID=""
SLACK_NGROK_DOMAIN=""

# ── Linear (MCP) ────────────────────────────────────────────
LINEAR_API_KEY=""

# ── Figma (Vite frontend + MCP) ─────────────────────────────
VITE_FIGMA_ACCESS_TOKEN=""

# ── Node environment ────────────────────────────────────────
NODE_ENV="development"
