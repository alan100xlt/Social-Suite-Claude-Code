# ============================================================
# Social Suite — Environment Variables
# ============================================================
# Copy this to .env.local and fill in your secrets:
#   cp .env.example .env.local
#
# Then run the setup script to distribute them:
#   bash scripts/setup-env.sh
#
# .env.local is gitignored — safe for real secrets.
# ============================================================

# ── Supabase (Vite frontend) ────────────────────────────────
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_PROJECT_ID="your-project-id"

# ── Supabase (MCP / CLI — personal access token) ────────────
SUPABASE_ACCESS_TOKEN=""

# ── Slack Agent Bridge ───────────────────────────────────────
SLACK_BOT_TOKEN=""
SLACK_SIGNING_SECRET=""
SLACK_CHANNEL_ID=""
SLACK_NGROK_DOMAIN=""

# ── Linear (MCP) ────────────────────────────────────────────
LINEAR_API_KEY=""

# ── Figma (Vite frontend + MCP) ─────────────────────────────
VITE_FIGMA_ACCESS_TOKEN=""

# ── Supabase Edge Function Secrets ─────────────────────────
# Synced to production via: bash scripts/setup-env.sh --push
# SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY are auto-provided.
ANTHROPIC_API_KEY=""
GETLATE_API_KEY=""
RESEND_API_KEY=""
FIRECRAWL_API_KEY=""
GEMINI_API_KEY=""
COURIER_AUTH_TOKEN=""
LINEAR_TEAM_ID=""
SITE_URL="https://social.longtale.ai"
BOOTSTRAP_SECRET=""
SEND_EMAIL_HOOK_SECRET=""
SLACK_WEBHOOK_URL=""

# ── Node environment ────────────────────────────────────────
NODE_ENV="development"
